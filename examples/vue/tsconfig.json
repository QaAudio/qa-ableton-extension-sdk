{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "paths": {
      "@quantumaudio/ableton-extension-sdk": ["../../src/index.ts"],
      "@quantumaudio/ableton-extension-sdk/vue": ["../../src/components/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
