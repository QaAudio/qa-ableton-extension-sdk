{
  "name": "qa-tempo-tap-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Beginner Ableton extension — tap tempo panel styled with @quantumaudio/ableton-extension-sdk (plain HTML, no Vue).",
  "type": "module",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run",
    "package": "npm run build && extensions-cli package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../../vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "@quantumaudio/ableton-extension-sdk": "file:../.."
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../../vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
