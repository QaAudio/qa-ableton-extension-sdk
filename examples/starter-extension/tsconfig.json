{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "rootDir": ".",
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "build.ts"]
}
