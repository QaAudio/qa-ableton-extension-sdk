# Path to Live's Extension Host module (required for `npm start` / extensions-cli run).
# Windows example:
# EXTENSION_HOST_PATH=C:\Program Files\Ableton\Live 12 Beta\Resources\Extensions\Extension Host.js
# macOS example:
# EXTENSION_HOST_PATH=/Applications/Ableton Live 12 Beta.app/Contents/Resources/Extensions/Extension Host.js

EXTENSION_HOST_PATH=
